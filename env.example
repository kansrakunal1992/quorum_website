# ── Quorum Website — Railway Environment Variables ─────────────────────
# Set these in: Railway Dashboard → Website Project → Variables
# Do NOT commit real values. This file is for reference only.
# ────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
# Both values required — server will exit on startup if either is missing.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# REQUIRED — Supabase project URL (same project as the app)

SUPABASE_SERVICE_KEY=eyJ_REPLACE_WITH_SERVICE_ROLE_KEY
# REQUIRED — Supabase service role key.
# Used SERVER-SIDE ONLY to insert waitlist form submissions.
# Never exposed in the browser or HTML source.
# Dashboard → Project Settings → API → service_role (secret)

# ── Port ─────────────────────────────────────────────────────────────────
# PORT is injected automatically by Railway. Do not set manually.
# PORT=3000
